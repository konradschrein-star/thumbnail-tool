generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model access_requests {
  id        String   @id
  name      String?
  email     String
  reason    String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([status])
}

model archetypes {
  id                 String               @id
  name               String
  imageUrl           String
  layoutInstructions String
  isAdminOnly        Boolean              @default(false)
  category           String?              @default("General")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  basePrompt         String?
  userId             String?
  users              users?               @relation(fields: [userId], references: [id])
  channel_archetypes channel_archetypes[]
  generation_jobs    generation_jobs[]

  @@index([userId])
}

model batch_jobs {
  id              String            @id
  userId          String?
  name            String
  status          BatchStatus       @default(PENDING)
  totalJobs       Int
  completedJobs   Int               @default(0)
  failedJobs      Int               @default(0)
  outputZipUrl    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  generation_jobs generation_jobs[]

  @@index([status])
  @@index([userId])
}

model channel_archetypes {
  id          String     @id
  channelId   String
  archetypeId String
  createdAt   DateTime   @default(now())
  archetypes  archetypes @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  channels    channels   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, archetypeId])
  @@index([archetypeId])
  @@index([channelId])
}

model channels {
  id                 String               @id
  name               String
  personaDescription String
  personaAssetPath   String?
  logoAssetPath      String?
  primaryColor       String?              @default("#ffffff")
  secondaryColor     String?              @default("#000000")
  tags               String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  userId             String?
  channel_archetypes channel_archetypes[]
  users              users?               @relation(fields: [userId], references: [id])
  generation_jobs    generation_jobs[]

  @@index([userId])
}

model generation_jobs {
  id             String         @id
  channelId      String
  archetypeId    String
  userId         String?
  videoTopic     String
  thumbnailText  String
  customPrompt   String?
  promptUsed     String?
  outputUrl      String?
  status         String         @default("pending")
  errorMessage   String?
  isManual       Boolean        @default(true)
  metadata       Json?
  createdAt      DateTime       @default(now())
  completedAt    DateTime?
  batchJobId     String?
  aiProvider     AIProvider     @default(AI33)
  fallbackUsed   Boolean        @default(false)
  fallbackReason String?
  archetypes     archetypes     @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  batch_jobs     batch_jobs?    @relation(fields: [batchJobId], references: [id])
  channels       channels       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  users          users?         @relation(fields: [userId], references: [id])
  variant_jobs   variant_jobs[]

  @@index([archetypeId])
  @@index([batchJobId])
  @@index([channelId])
  @@index([channelId, status])
  @@index([status])
  @@index([userId])
}

model google_sheets_connections {
  id           String   @id
  userId       String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  sheetId      String?
  sheetName    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@index([userId])
}

model users {
  id              String            @id
  email           String            @unique
  password        String
  name            String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  role            String            @default("USER")
  preferences     Json?
  archetypes      archetypes[]
  channels        channels[]
  generation_jobs generation_jobs[]
}

model variant_jobs {
  id              String           @id
  masterJobId     String?
  language        String
  translatedText  String
  originalText    String?
  outputUrl       String?
  status          String           @default("pending")
  errorMessage    String?
  sourceImageUrl  String?
  translationMode String           @default("MASTER_JOB")
  createdAt       DateTime         @default(now())
  completedAt     DateTime?
  generation_jobs generation_jobs? @relation(fields: [masterJobId], references: [id], onDelete: Cascade)

  @@index([masterJobId])
}

enum AIProvider {
  AI33
  GOOGLE
}

enum BatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}
