generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model access_requests {
  id        String   @id @default(cuid())
  name      String?
  email     String
  reason    String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model archetypes {
  id                 String               @id @default(cuid())
  name               String
  imageUrl           String
  layoutInstructions String
  isAdminOnly        Boolean              @default(false)
  category           String?              @default("General")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  basePrompt         String?
  userId             String?
  users              users?               @relation(fields: [userId], references: [id])
  channel_archetypes channel_archetypes[]
  generation_jobs    generation_jobs[]

  @@unique([userId, name])
  @@index([userId])
}

model channel_archetypes {
  id          String     @id @default(cuid())
  channelId   String
  archetypeId String
  createdAt   DateTime   @default(now())
  archetypes  archetypes @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  channels    channels   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, archetypeId])
  @@index([archetypeId])
  @@index([channelId])
}

model channels {
  id                 String               @id @default(cuid())
  name               String
  personaDescription String
  personaAssetPath   String?
  logoAssetPath      String?
  primaryColor       String?              @default("#ffffff")
  secondaryColor     String?              @default("#000000")
  tags               String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  userId             String?
  channel_archetypes channel_archetypes[]
  users              users?               @relation(fields: [userId], references: [id])
  generation_jobs    generation_jobs[]

  @@unique([userId, name])
  @@index([userId])
}

model credit_transactions {
  id               String   @id @default(cuid())
  user_id          String
  transaction_type String
  amount           Int
  balance_before   Int
  balance_after    Int
  reason           String
  related_job_id   String?
  related_batch_id String?
  admin_user_id    String?
  metadata         Json?
  created_at       DateTime @default(now())
  users            users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([transaction_type])
  @@index([user_id, created_at])
  @@index([user_id])
}

model generation_jobs {
  id               String         @id @default(cuid())
  channelId        String
  archetypeId      String
  userId           String?
  videoTopic       String
  thumbnailText    String
  customPrompt     String?
  promptUsed       String?
  outputUrl        String?
  status           String         @default("pending")
  errorMessage     String?
  isManual         Boolean        @default(true)
  metadata         Json?
  createdAt        DateTime       @default(now())
  completedAt      DateTime?
  credits_deducted Int?
  batchJobId       String?
  archetypes       archetypes     @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  batch_jobs       batch_jobs?    @relation(fields: [batchJobId], references: [id], onDelete: Cascade)
  channels         channels       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  users            users?         @relation(fields: [userId], references: [id])
  variant_jobs     variant_jobs[]

  @@index([archetypeId])
  @@index([batchJobId])
  @@index([channelId])
  @@index([channelId, status])
  @@index([createdAt])
  @@index([status])
  @@index([userId])
  @@index([userId, isManual])
}

model batch_jobs {
  id               String            @id @default(cuid())
  name             String
  userId           String
  status           String            @default("PENDING")
  totalJobs        Int
  completedJobs    Int               @default(0)
  failedJobs       Int               @default(0)
  outputZipUrl     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  credits_deducted Int?
  users            users             @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation_jobs  generation_jobs[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model users {
  id                      String                @id @default(cuid())
  email                   String                @unique
  password                String
  name                    String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  role                    String                @default("USER")
  preferences             Json?
  credits                 Int                   @default(0)
  password_hash_algorithm String                @default("bcrypt")
  total_credits_consumed  Int                   @default(0)
  total_credits_granted   Int                   @default(0)
  archetypes              archetypes[]
  batch_jobs              batch_jobs[]
  channels                channels[]
  credit_transactions     credit_transactions[]
  generation_jobs         generation_jobs[]
}

model variant_jobs {
  id              String           @id @default(cuid())
  masterJobId     String?
  language        String
  translatedText  String
  outputUrl       String?
  status          String           @default("pending")
  errorMessage    String?
  createdAt       DateTime         @default(now())
  completedAt     DateTime?
  originalText    String?
  sourceImageUrl  String?
  translationMode String           @default("MASTER_JOB")
  metadata        Json?
  generation_jobs generation_jobs? @relation(fields: [masterJobId], references: [id], onDelete: Cascade)

  @@index([masterJobId])
}
