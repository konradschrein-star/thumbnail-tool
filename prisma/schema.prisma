generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AIProvider {
  AI33
  GOOGLE
}

enum BatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  name           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  role           String          @default("USER")
  preferences    Json?           // Store custom languages and other user settings
  channels       Channel[]       @relation("UserChannels")
  archetypes     Archetype[]
  generationJobs GenerationJob[]

  @@map("users")
}

model Channel {
  id                 String             @id @default(cuid())
  name               String
  personaDescription String
  personaAssetPath   String?
  logoAssetPath      String?
  primaryColor       String?            @default("#ffffff")
  secondaryColor     String?            @default("#000000")
  tags               String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  userId             String?
  archetypes         ChannelArchetype[]
  user               User?              @relation("UserChannels", fields: [userId], references: [id])
  generationJobs     GenerationJob[]

  @@index([userId])
  @@map("channels")
}

model Archetype {
  id                 String             @id @default(cuid())
  name               String
  imageUrl           String
  layoutInstructions String
  isAdminOnly        Boolean            @default(false)
  category           String?            @default("General")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  basePrompt         String?
  userId             String?
  channels           ChannelArchetype[]
  user               User?              @relation(fields: [userId], references: [id])
  generationJobs     GenerationJob[]

  @@index([userId])
  @@map("archetypes")
}

model ChannelArchetype {
  id          String    @id @default(cuid())
  channelId   String
  archetypeId String
  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  archetype   Archetype @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([channelId, archetypeId])
  @@index([channelId])
  @@index([archetypeId])
  @@map("channel_archetypes")
}

model GenerationJob {
  id            String       @id @default(cuid())
  channelId     String
  archetypeId   String
  userId        String?
  videoTopic    String
  thumbnailText String
  customPrompt  String?
  promptUsed    String?
  outputUrl     String?
  status        String       @default("pending")
  errorMessage  String?
  isManual      Boolean      @default(true)
  metadata      Json?
  createdAt     DateTime     @default(now())
  completedAt   DateTime?
  archetype     Archetype    @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  channel       Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [userId], references: [id])
  variants      VariantJob[]

  // NEW: Batch processing fields
  batchJobId      String?
  batchJob        BatchJob?       @relation(fields: [batchJobId], references: [id], onDelete: SetNull)
  aiProvider      AIProvider      @default(AI33)
  fallbackUsed    Boolean         @default(false)
  fallbackReason  String?         @db.Text

  @@index([channelId])
  @@index([archetypeId])
  @@index([userId])
  @@index([status])
  @@index([channelId, status])
  @@index([batchJobId])
  @@map("generation_jobs")
}

model VariantJob {
  id              String         @id @default(cuid())
  masterJobId     String?        // Optional - null for uploaded images
  language        String
  translatedText  String
  originalText    String?        // Original text before translation
  outputUrl       String?
  status          String         @default("pending")
  errorMessage    String?
  sourceImageUrl  String?        // For uploaded images (not from master job)
  translationMode String         @default("MASTER_JOB") // "MASTER_JOB" or "UPLOADED_IMAGE"
  createdAt       DateTime       @default(now())
  completedAt     DateTime?
  masterJob       GenerationJob? @relation(fields: [masterJobId], references: [id], onDelete: Cascade)

  @@index([masterJobId])
  @@map("variant_jobs")
}

model BatchJob {
  id              String          @id @default(cuid())
  userId          String?
  name            String
  status          BatchStatus     @default(PENDING)
  totalJobs       Int
  completedJobs   Int             @default(0)
  failedJobs      Int             @default(0)
  outputZipUrl    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  jobs            GenerationJob[]

  @@index([status])
  @@index([userId])
  @@map("batch_jobs")
}

model GoogleSheetsConnection {
  id              String          @id @default(cuid())
  userId          String          @unique
  accessToken     String          @db.Text
  refreshToken    String          @db.Text
  expiresAt       DateTime
  sheetId         String?
  sheetName       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@map("google_sheets_connections")
}

model AccessRequest {
  id        String   @id @default(cuid())
  name      String?
  email     String
  reason    String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("access_requests")
}
