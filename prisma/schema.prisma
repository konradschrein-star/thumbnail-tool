generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String              @id @default(cuid())
  email                   String              @unique
  password                String
  name                    String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  role                    String              @default("USER")
  preferences             Json?
  credits                 Int                 @default(0)
  password_hash_algorithm String              @default("bcrypt")
  totalCreditsConsumed    Int                 @default(0) @map("total_credits_consumed")
  totalCreditsGranted     Int                 @default(0) @map("total_credits_granted")
  archetypes              Archetype[]
  channels                Channel[]           @relation("UserChannels")
  credit_transactions     CreditTransaction[]
  generationJobs          GenerationJob[]

  @@map("users")
}

model Channel {
  id                 String             @id @default(cuid())
  name               String
  personaDescription String
  personaAssetPath   String?
  logoAssetPath      String?
  primaryColor       String?            @default("#ffffff")
  secondaryColor     String?            @default("#000000")
  tags               String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  userId             String?
  archetypes         ChannelArchetype[]
  user               User?              @relation("UserChannels", fields: [userId], references: [id])
  generationJobs     GenerationJob[]

  @@unique([userId, name])
  @@index([userId])
  @@map("channels")
}

model Archetype {
  id                 String             @id @default(cuid())
  name               String
  imageUrl           String
  layoutInstructions String
  isAdminOnly        Boolean            @default(false)
  category           String?            @default("General")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  basePrompt         String?
  userId             String?
  user               User?              @relation(fields: [userId], references: [id])
  channels           ChannelArchetype[]
  generationJobs     GenerationJob[]

  @@unique([userId, name])
  @@index([userId])
  @@map("archetypes")
}

model ChannelArchetype {
  id          String    @id @default(cuid())
  channelId   String
  archetypeId String
  createdAt   DateTime  @default(now())
  archetype   Archetype @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, archetypeId])
  @@index([channelId])
  @@index([archetypeId])
  @@map("channel_archetypes")
}

model GenerationJob {
  id               String       @id @default(cuid())
  channelId        String
  archetypeId      String
  userId           String?
  videoTopic       String
  thumbnailText    String
  customPrompt     String?
  promptUsed       String?
  outputUrl        String?
  status           String       @default("pending")
  errorMessage     String?
  isManual         Boolean      @default(true)
  metadata         Json?
  createdAt        DateTime     @default(now())
  completedAt      DateTime?
  credits_deducted Int?
  archetype        Archetype    @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  channel          Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user             User?        @relation(fields: [userId], references: [id])
  variants         VariantJob[]

  @@index([channelId])
  @@index([archetypeId])
  @@index([userId])
  @@index([status])
  @@index([channelId, status])
  @@index([createdAt])
  @@index([userId, isManual])
  @@map("generation_jobs")
}

model VariantJob {
  id              String         @id @default(cuid())
  masterJobId     String?
  language        String
  translatedText  String
  outputUrl       String?
  status          String         @default("pending")
  errorMessage    String?
  createdAt       DateTime       @default(now())
  completedAt     DateTime?
  originalText    String?
  sourceImageUrl  String?
  translationMode String         @default("MASTER_JOB")
  masterJob       GenerationJob? @relation(fields: [masterJobId], references: [id], onDelete: Cascade)

  @@index([masterJobId])
  @@map("variant_jobs")
}

model AccessRequest {
  id        String   @id @default(cuid())
  name      String?
  email     String
  reason    String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("access_requests")
}

model CreditTransaction {
  id               String   @id @default(cuid())
  user_id          String
  transaction_type String
  amount           Int
  balance_before   Int
  balance_after    Int
  reason           String
  related_job_id   String?
  related_batch_id String?
  admin_user_id    String?
  metadata         Json?
  created_at       DateTime @default(now())
  users            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([transaction_type])
  @@index([user_id, created_at])
  @@index([user_id])
  @@map("credit_transactions")
}
