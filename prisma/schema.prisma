generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model access_requests {
  id        String   @id @default(cuid())
  name      String?
  email     String
  reason    String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model archetypes {
  id                 String               @id @default(cuid())
  name               String
  imageUrl           String
  layoutInstructions String
  isAdminOnly        Boolean              @default(false)
  category           String?              @default("General")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  basePrompt         String?
  userId             String?
  users              users?               @relation(fields: [userId], references: [id])
  channel_archetypes channel_archetypes[]
  generation_jobs    generation_jobs[]

  @@index([userId])
}

model batch_jobs {
  id              String            @id @default(cuid())
  userId          String?
  name            String
  status          BatchStatus       @default(PENDING)
  totalJobs       Int
  completedJobs   Int               @default(0)
  failedJobs      Int               @default(0)
  outputZipUrl    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  generation_jobs generation_jobs[]

  @@index([status])
  @@index([userId])
}

model channel_archetypes {
  id          String     @id @default(cuid())
  channelId   String
  archetypeId String
  createdAt   DateTime   @default(now())
  archetypes  archetypes @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  channels    channels   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, archetypeId])
  @@index([archetypeId])
  @@index([channelId])
}

model channels {
  id                 String               @id @default(cuid())
  name               String
  personaDescription String
  personaAssetPath   String?
  logoAssetPath      String?
  primaryColor       String?              @default("#ffffff")
  secondaryColor     String?              @default("#000000")
  tags               String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  userId             String?
  channel_archetypes channel_archetypes[]
  users              users?               @relation(fields: [userId], references: [id])
  generation_jobs    generation_jobs[]

  @@index([userId])
}

model generation_jobs {
  id             String         @id @default(cuid())
  channelId      String
  archetypeId    String
  userId         String?
  videoTopic     String
  thumbnailText  String
  customPrompt   String?
  promptUsed     String?
  outputUrl      String?
  status         String         @default("pending")
  errorMessage   String?
  isManual       Boolean        @default(true)
  metadata       Json?
  createdAt      DateTime       @default(now())
  completedAt    DateTime?
  batchJobId     String?
  aiProvider     AIProvider     @default(AI33)
  fallbackUsed   Boolean        @default(false)
  fallbackReason String?
  archetypes          archetypes            @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  batch_jobs          batch_jobs?           @relation(fields: [batchJobId], references: [id])
  channels            channels              @relation(fields: [channelId], references: [id], onDelete: Cascade)
  users               users?                @relation(fields: [userId], references: [id])
  variant_jobs        variant_jobs[]
  credit_transactions credit_transactions[]

  @@index([archetypeId])
  @@index([batchJobId])
  @@index([channelId])
  @@index([channelId, status])
  @@index([status])
  @@index([userId])
}

model google_sheets_connections {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  sheetId      String?
  sheetName    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model users {
  id                      String                @id @default(cuid())
  email                   String                @unique
  password                String
  passwordHashAlgorithm   String?               @default("bcrypt")
  name                    String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  role                    String                @default("USER")
  preferences             Json?
  credits                 Int                   @default(0)
  totalCreditsGranted     Int                   @default(0)
  totalCreditsConsumed    Int                   @default(0)
  archetypes              archetypes[]
  channels                channels[]
  generation_jobs         generation_jobs[]
  credit_transactions     credit_transactions[] @relation("UserCredits")
  admin_transactions      credit_transactions[] @relation("AdminGrants")
}

model credit_transactions {
  id               String           @id @default(cuid())
  userId           String
  adminId          String?
  transaction_type String
  amount           Int
  balanceBefore    Int?
  balanceAfter     Int
  reason           String?
  relatedJobId     String?
  createdAt        DateTime         @default(now())
  users            users            @relation("UserCredits", fields: [userId], references: [id])
  admin            users?           @relation("AdminGrants", fields: [adminId], references: [id])
  generation_jobs  generation_jobs? @relation(fields: [relatedJobId], references: [id])

  @@index([userId])
  @@index([adminId])
  @@index([createdAt])
}

model variant_jobs {
  id              String           @id
  masterJobId     String?
  language        String
  translatedText  String
  originalText    String?
  outputUrl       String?
  status          String           @default("pending")
  errorMessage    String?
  sourceImageUrl  String?
  translationMode String           @default("MASTER_JOB")
  createdAt       DateTime         @default(now())
  completedAt     DateTime?
  generation_jobs generation_jobs? @relation(fields: [masterJobId], references: [id], onDelete: Cascade)

  @@index([masterJobId])
}

enum AIProvider {
  AI33
  GOOGLE
}

enum BatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}
