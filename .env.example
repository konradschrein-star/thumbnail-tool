# ====================
# PRODUCTION DEPLOYMENT NOTES
# ====================
# 1. Generate ENCRYPTION_KEY: openssl rand -hex 32
# 2. Generate NEXTAUTH_SECRET: openssl rand -base64 32
# 3. Set strong POSTGRES_PASSWORD
# 4. Configure Google OAuth credentials at https://console.cloud.google.com/
#
# Port Configuration:
# - PORT=3072 (Next.js)
# - PostgreSQL: 5433
# - Redis: 6380
#
# Complete isolation from Content Forge (ports 3000, 5432, 6379)

# Node Environment
NODE_ENV=development
PORT=3072

# Database
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5433/thumbnail_generator

# Redis
REDIS_URL=redis://localhost:6380

# AI Providers
GOOGLE_API_KEY=your_google_api_key_here
AI33_API_KEY=your_ai33_api_key_here

# Cloudflare R2 Storage
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=thumbnails
R2_PUBLIC_URL=https://pub-your_account_id.r2.dev

# Authentication
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=https://thumbnails.schreinercontentsystems.com

# Email
RESEND_API_KEY=your_resend_api_key_here

# Google Sheets OAuth
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Encryption Key (for OAuth tokens)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=generate_32_byte_hex_key

# Docker
POSTGRES_PASSWORD=choose_strong_password
