# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
#
# This file contains example configuration for both development and production
# environments. For production deployments:
#
# 1. Never commit .env files to version control
# 2. Use your platform's secret management (e.g., Vercel Secrets, AWS Secrets Manager)
# 3. Generate all random values using cryptographically secure methods
# 4. Rotate credentials regularly
#
# ============================================================================

# Node Environment
# Options: development, production, staging
NODE_ENV=production
PORT=3000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string with separate direct URL for migrations
#
# PRODUCTION NOTE:
# - Use managed PostgreSQL service (e.g., Railway, Supabase, AWS RDS)
# - Enable connection pooling for production
# - Keep DIRECT_URL as a non-pooled connection for migrations
# - Example with Railway: postgresql://user:password@host:port/database
# - Example with Supabase: postgresql://postgres.project:password@host/postgres

DATABASE_URL=postgresql://user:password@host:5432/thumbnail_generator?schema=public
DIRECT_URL=postgresql://user:password@host:5432/thumbnail_generator?schema=public

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Redis connection for BullMQ job queue
#
# PRODUCTION NOTE:
# - Use managed Redis service (e.g., Redis Cloud, Upstash, AWS ElastiCache)
# - Never expose Redis without authentication
# - Example with Upstash: redis://default:password@host:port
# - Enable TLS in production: rediss://... (note the double 's')
# - Set max connections and timeouts appropriately

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Alternative: Complete Redis URL
# REDIS_URL=redis://user:password@host:port/db?ssl=true

# ============================================================================
# AI PROVIDERS CONFIGURATION
# ============================================================================
# API keys for image generation providers
#
# PRODUCTION NOTE:
# - Store all API keys in secret management systems
# - Rotate API keys periodically
# - Monitor usage and implement rate limiting
# - Primary: AI33 (with automatic Google fallback)

GOOGLE_API_KEY=your_google_gemini_api_key
AI33_API_KEY=your_ai33_api_key

# ============================================================================
# LOCAL STORAGE CONFIGURATION
# ============================================================================
# Path for storing generated thumbnails locally
#
# PRODUCTION NOTE:
# - Use persistent volume or NFS mount in containerized environments
# - For cloud deployments (Vercel, Netlify), consider:
#   * Local temp storage + automated upload to cloud storage (S3, GCS)
#   * Or use cloud-native storage SDK integration
# - Set retention days to manage disk usage
# - Monitor disk space utilization

STORAGE_PATH=/opt/thumbnail-generator/storage/thumbnails
STORAGE_RETENTION_DAYS=30

# PRODUCTION CLOUD STORAGE (Optional - for backup/archive)
# If using S3, GCS, or other cloud storage:
# AWS_S3_BUCKET=your-bucket
# AWS_REGION=us-east-1
# GCS_BUCKET=your-bucket
# GCS_PROJECT_ID=your-project

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# NextAuth.js configuration for user authentication
#
# PRODUCTION NOTE:
# - Generate with: openssl rand -base64 32
# - NEXTAUTH_URL must match your production domain
# - Use HTTPS URLs in production
# - Enable secure cookie settings in production

NEXTAUTH_SECRET=your_nextauth_secret_from_openssl_rand_base64_32
NEXTAUTH_URL=https://yourdomain.com

# ============================================================================
# GOOGLE SHEETS OAUTH
# ============================================================================
# Google Cloud OAuth 2.0 credentials for Sheets integration
#
# PRODUCTION NOTE:
# - Create OAuth 2.0 credentials in Google Cloud Console
# - Set authorized redirect URIs to: https://yourdomain.com/api/sheets/callback
# - Store client ID and secret in secret management
# - Rotate credentials periodically

GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ============================================================================
# ENCRYPTION
# ============================================================================
# Encryption key for OAuth tokens and sensitive data
#
# PRODUCTION NOTE:
# - Generate with: openssl rand -hex 32
# - Store securely in secret management system
# - Rotation requires re-encryption of existing data

ENCRYPTION_KEY=your_encryption_key_from_openssl_rand_hex_32

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
# Configure logging levels and monitoring
#
# PRODUCTION NOTE:
# - Use structured logging (JSON format)
# - Send logs to centralized logging service (e.g., LogRocket, DataDog, ELK)

LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# ============================================================================
# RATE LIMITING
# ============================================================================
# API rate limiting configuration
#
# PRODUCTION NOTE:
# - Configure per user, per IP, and per API endpoint
# - Adjust based on your scale and usage patterns

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# DEPLOYMENT PLATFORM SPECIFIC
# ============================================================================

# Vercel-specific environment variables (auto-configured, shown for reference)
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=yourdomain.com

# Docker-specific (if using Docker Compose)
POSTGRES_PASSWORD=your_postgres_strong_password
POSTGRES_USER=postgres
POSTGRES_DB=thumbnail_generator
